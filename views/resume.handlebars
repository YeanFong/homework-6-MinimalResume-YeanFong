{{#section "styles"}}
<style>
  body {
    margin: 0;
    background: #fff;
    font-family: "Times New Roman", Times, serif;
    color: #000;
  }
  .page {
    width: 900px;
    margin: 24px auto;
  }

  .cv-title {
    text-align: center;
    margin-top: 10px;
  }
  .cv-title h1 {
    margin: 0;
    font-size: 44px;
    font-weight: normal;
  }
  .cv-title-line {
    margin: 10px auto 0;
    width: 100%;
    height: 1px;
    background: #000;
  }

  .cv-section {
    margin-top: 28px;
  }
  .cv-section-title {
    font-weight: bold;
    letter-spacing: 0.5px;
    text-transform: uppercase;
  }
  .cv-section-rule {
    margin-top: 6px;
    height: 1px;
    background: #000;
  }
  .cv-section-body {
    margin-top: 14px;
  }

  /* Two-column rows (left content, right date) */
  .row {
    display: grid;
    grid-template-columns: 1fr 180px;
    gap: 10px;
    margin: 14px 0;
  }
  .row-right {
    text-align: right;
    white-space: nowrap;
    font-weight: bold;
  }
  .row-topline {
    font-size: 18px;
  }
  .row-bold { font-weight: bold; }
  .row-sep { padding: 0 8px; }
  .row-sub {
    margin-top: 4px;
    font-size: 18px;
  }
  .row-italic {
    font-style: italic;
    margin-top: 2px;
  }
  .bullets {
    margin: 8px 0 0 20px;
  }
  .bullets li {
    margin: 6px 0;
  }

  /* Personal details */
  .personal-grid {
    display: grid;
    grid-template-columns: 1fr 180px;
    gap: 20px;
    align-items: start;
  }
  .photo-box {
    border: 1px solid #000;
    padding: 10px;
    width: 160px;
    height: 190px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .photo-box img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .details-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 18px;
  }
  .details-table td {
    padding: 3px 0;
    vertical-align: top;
  }
  .details-label {
    width: 140px;
    font-weight: bold;
    padding-right: 12px;
  }
</style>
{{/section}}

<div class="page">
  {{> resumeHeader}}

  {{#> resumeSection title="PERSONAL DETAILS"}}
    <div class="personal-grid">
      <div>
        <table class="details-table">
          <tr>
            <td class="details-label">Address:</td>
            <td>
              {{#each resume.personal.addressLines}}
                <div>{{this}}</div>
              {{/each}}
            </td>
          </tr>
          <tr>
            <td class="details-label">Telephone:</td>
            <td>{{resume.personal.telephone}}</td>
          </tr>
          <tr>
            <td class="details-label">Email:</td>
            <td>{{resume.personal.email}}</td>
          </tr>
          <tr>
            <td class="details-label">Date of Birth:</td>
            <td>{{resume.personal.dob}}</td>
          </tr>
          <tr>
            <td class="details-label">Nationality:</td>
            <td>{{resume.personal.nationality}}</td>
          </tr>
        </table>
      </div>

      <div class="photo-box">
        <img src="{{resume.personal.photoUrl}}" alt="Profile photo"/>
      </div>
    </div>
  {{/resumeSection}}

  {{#> resumeSection title="EDUCATION"}}
    {{#each resume.education}}
      {{> eduItem
        leftTitle=this.leftTitle
        leftMeta=this.leftMeta
        rightDate=this.rightDate
        subLine=this.subLine
        bullets=this.bullets
      }}
    {{/each}}
  {{/resumeSection}}

  {{#> resumeSection title="WORK EXPERIENCE"}}
    {{#each resume.experience}}
      {{> expItem
        roleOrg=this.roleOrg
        location=this.location
        rightDate=this.rightDate
        bullets=this.bullets
      }}
    {{/each}}
  {{/resumeSection}}
  
  {{! if + unless --}}
  {{#if resume.showSkills}}
    {{#> resumeSection title="SKILLS"}}
      <div class="row" style="grid-template-columns: 1fr; margin: 0;">
        <div class="row-left">
          <div>
            <span class="row-bold">Digital Skills:</span>
            {{resume.skills.digital}}
          </div>

          <div style="margin-top:6px;">
            <span class="row-bold">Languages:</span>
            {{resume.skills.languages}}
          </div>
        </div>
      </div>
    {{/resumeSection}}
  {{/if}}

  {{#unless resume.showSkills}}
    <div style="margin-top: 18px; font-style: italic;">
      Skills section hidden (demonstrates <code>\{{#unless}}</code>).
    </div>
  {{/unless}}
</div>