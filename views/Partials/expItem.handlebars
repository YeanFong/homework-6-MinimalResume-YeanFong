<div class="row">
  <div class="row-left">
    <div class="row-topline">
      <span class="row-bold">{{roleOrg}}</span>
    </div>

    <div class="row-italic">{{location}}</div>

    <ul class="bullets">
      {{#each bullets}}
        <li>{{this}}</li>
      {{/each}}
    </ul>
  </div>

  <div class="row-right">
    <div class="row-date">{{rightDate}}</div>
  </div>
</div>